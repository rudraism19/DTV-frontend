# ══════════════════════════════════════════════════════════════════════════════
# DIGITAL TWIN VERSE — PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# ══════════════════════════════════════════════════════════════════════════════

# ── 1. General & Server Config ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://digital-twin-app.onrender.com

# ── 2. Supabase Live Database Config (PostgreSQL) ─────────────────────────────
# Get this from Supabase Dashboard -> Project Settings -> Database -> Connection String (URI)
DATABASE_URL=postgres://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require
DB_POOL_MAX=15
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=5000
DB_SSL_OFF=false

# Supabase API (Optional for direct client/Edge integrations)
SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── 3. JWT Security Secrets ───────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secure_jwt_access_secret_key_here_32_bytes_long
JWT_REFRESH_SECRET=your_super_secure_jwt_refresh_secret_key_here_32_bytes_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_SECURE=true
CORS_ORIGINS=https://digital-twin-app.onrender.com

# ── 4. Razorpay Live Payment Gateway ──────────────────────────────────────────
# Get this from Razorpay Dashboard -> Settings -> API Keys -> Live Mode
RAZORPAY_KEY_ID=rzp_live_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# ── 5. Brevo Automated Email SMTP ─────────────────────────────────────────────
# Get this from Brevo Dashboard -> SMTP & API -> API Keys
BREVO_API_KEY=xkeysib-your_brevo_api_key_here

# ── 6. AI Advisor Engine Config ("Ask AI for Study Plan") ─────────────────────
# AI_PROVIDER can be 'auto', 'openai', or 'anthropic'
AI_PROVIDER=auto
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── 7. Optional File Storage & Cloud Services ─────────────────────────────────
FILE_STORAGE=local
UPLOAD_DIR=uploads
SENTRY_DSN=
