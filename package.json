{
  "name": "digital-twin-students",
  "version": "1.0.0",
  "private": true,
  "description": "Digital Twin for Students - secure full-stack web app",
  "main": "src/server.js",
  "scripts": {
    "build": "node scripts/build-frontend.js && npm --prefix parent-ui install && npm --prefix parent-ui run build",
    "start": "npm run db:migrate && node scripts/migrate_payment.js && npm run build && node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed-admin": "node scripts/seed-admin.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "deploy": "npm run build && node scripts/deploy.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.873.0",
    "@sentry/node": "^8.27.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.1",
    "google-auth-library": "^10.0.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.5.0",
    "joi": "^17.13.3",
    "jsdom": "^29.1.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "ms": "^2.1.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.13.1",
    "razorpay": "^2.9.6",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "puppeteer": "^25.1.0",
    "supertest": "^7.0.0"
  },
  "overrides": {
    "bcrypt": {
      "@mapbox/node-pre-gyp": {
        "tar": "^7.4.3"
      }
    }
  },
  "directories": {
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/25tec2se234-oss/digital-twin-app.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/25tec2se234-oss/digital-twin-app/issues"
  },
  "homepage": "https://github.com/25tec2se234-oss/digital-twin-app#readme"
}
